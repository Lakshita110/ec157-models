# Copy to .env for local dev. Never commit real values.
GARMIN_EMAIL=
GARMIN_PASSWORD=

# Notion is READ-ONLY (habits/knee log + tasks). Share both databases with
# the integration (docs/notion_schema.md). DB IDs default to the real
# workspace databases in config.py; override only if they move.
NOTION_TOKEN=
#NOTION_KNEE_LOG_DB_ID=
#NOTION_TASKS_DB_ID=

OPENROUTER_API_KEY=
TAVILY_API_KEY=

DATABASE_URL=postgresql://jim:jim@localhost:5432/jim
APP_TIMEZONE=America/New_York

# Long random string; enables the built-in web chat at /chat?key=<CHAT_SECRET>
CHAT_SECRET=
