# Copy to .env for local dev. Never commit real values.
GARMIN_EMAIL=
GARMIN_PASSWORD=

# Notion is READ-ONLY and supplies only the habits/knee log. Share that database
# with the integration (docs/notion_schema.md). The DB ID defaults to the real
# workspace database in config.py; override only if it moves.
# Scheduling context comes from Garmin — there is no tasks DB.
NOTION_TOKEN=
#NOTION_KNEE_LOG_DB_ID=

OPENROUTER_API_KEY=
TAVILY_API_KEY=

DATABASE_URL=postgresql://jim:jim@localhost:5432/jim
APP_TIMEZONE=America/New_York

# Long random string; enables the built-in web chat at /chat?key=<CHAT_SECRET>
CHAT_SECRET=
